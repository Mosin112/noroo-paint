# Copy to .env (or .env.local) and fill in real values.
# Expo loads EXPO_PUBLIC_* variables into the JS bundle automatically.

# Supabase project — Settings → API in the dashboard.
# REQUIRED in production builds; missing vars hard-fail at boot via src/lib/env.ts.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-KEY

# Sentry crash reporting. Optional — no-ops when unset.
# Create a Project → Settings → Client Keys (DSN) in Sentry.
EXPO_PUBLIC_SENTRY_DSN=

# OPTIONAL: only set if a NestJS API layer is in the middle (PRD §2).
# Without it the app talks to Supabase directly.
# EXPO_PUBLIC_API_BASE_URL=https://api.noroopaint.com.au/v1
