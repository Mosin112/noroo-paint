{
  "expo": {
    "name": "Paint Express",
    "slug": "noroo-paint",
    "scheme": "noroopaint",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#f6f3ec",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f6f3ec"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "au.com.axepayments.noroopaint",
      "buildNumber": "1"
    },
    "android": {
      "package": "au.com.axepayments.noroopaint",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#1c1b18",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#f6f3ec"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#f6f3ec"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2157058f-8fe9-4352-8b04-b4e876a5a9af"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2157058f-8fe9-4352-8b04-b4e876a5a9af"
    }
  }
}
